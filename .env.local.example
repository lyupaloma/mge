# Скопируй этот файл в .env.local и заполни своими данными

# SMTP-сервер (пример для Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password   # Gmail: нужен "App Password", не основной пароль

# Куда приходят заявки
MAIL_TO=info@mgedna.kz
